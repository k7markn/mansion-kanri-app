# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma) - Supabase Transaction Pooler (port 6543)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# Prisma Migrate 用 Session Pooler (port 5432)
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# メール通知 (Resend)
RESEND_API_KEY=re_your-api-key

# アプリURL（本番時に設定）
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# シード用 Supabase Auth ユーザーID（Authentication → Users で確認）
SEED_ADMIN_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SEED_BOARD_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SEED_RESIDENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
